# Stack Finder (OpenRouter)
OPENROUTER_API_KEY=

# Public site URL (no trailing slash) — used for MoonPay redirect + webhook docs
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Convex (orders) — filled by `npx convex dev`
# Deployment used by `npx convex dev`
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=
# Shared secret: Next.js MoonPay webhook → Convex `orders.updateStatusFromWebhook`
# Generate a long random string; set the SAME value in Convex:
#   npx convex env set ORDERS_WEBHOOK_SECRET '<same-value>'
ORDERS_WEBHOOK_SECRET=

# MoonPay hosted on-ramp (buy widget) — https://dashboard.moonpay.com/
# Publishable / public API key (pk_test_… or pk_live_…)
MOONPAY_API_KEY=
# Secret key for URL signing when walletAddress is set (sk_test_… or sk_live_…)
MOONPAY_SECRET_KEY=
# Webhook signing key from MoonPay Developers → webhooks (Moonpay-Signature-V2)
MOONPAY_WEBHOOK_SECRET=
# Destination wallet that receives purchased crypto (confirm chain matches currency)
MOONPAY_WALLET_ADDRESS=
# Crypto settlement currency code (e.g. usdc). Must match wallet/network support.
MOONPAY_DEFAULT_CURRENCY=usdc
# sandbox | production — selects buy-sandbox.moonpay.com vs buy.moonpay.com
MOONPAY_ENVIRONMENT=sandbox
